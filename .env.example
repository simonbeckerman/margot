# Local Edge Function testing (optional). Production uses `supabase secrets set`.
# COMPANION_TOKEN_SIMON=
# COMPANION_TOKEN_CHIARA=
# MCP_OAUTH_JWT_SECRET=  # required for Claude “Add custom connector” (OAuth signing)
# MCP_OAUTH_CONSENT_PAGE_URL=  # optional: HTTPS URL of hosted docs/oauth-consent.html (default *.supabase.co cannot render HTML; see docs/CONNECT.md)
# SUPABASE_URL=         # set automatically when using supabase functions serve
# SUPABASE_SERVICE_ROLE_KEY=
